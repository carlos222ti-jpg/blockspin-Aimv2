userInputService.InputBegan:Connect(function(input: InputObject, gameProcessed: boolean)
	if gameProcessed then
		return
	end
	if input.KeyCode == AIMBOT_KEY then
		keyHeld = true
		if not aimbotEnabled then
			aimbotEnabled = true
			aimbotBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
			aimbotBtn.Text = "Aimbot: ON [E]"
		end
	end
end)

userInputService.InputEnded:Connect(function(input: InputObject)
	if input.KeyCode == AIMBOT_KEY then
		keyHeld = false
		if aimbotEnabled then
			aimbotEnabled = false
			aimbotBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
			aimbotBtn.Text = "Aimbot: OFF [E]"
		end
	end
end)

-- Slider drag
local draggingSlider: boolean = false

sliderThumb.InputBegan:Connect(function(input: InputObject)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		draggingSlider = true
	end
end)

sliderThumb.InputEnded:Connect(function(input: InputObject)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		draggingSlider = false
	end
end)

userInputService.InputChanged:Connect(function(input: InputObject)
	if not draggingSlider then
		return
	end
	if input.UserInputType ~= Enum.UserInputType.MouseMovement then
		return
	end

	local absPos: Vector2 = sliderTrack.AbsolutePosition
	local absSize: number = sliderTrack.AbsoluteSize.X
	local mouseX: number = userInputService:GetMouseLocation().X
	local ratio: number = math.clamp((mouseX - absPos.X) / absSize, 0, 1)

	fovSize = math.floor(MIN_FOV + ratio * (MAX_FOV - MIN_FOV))
	sliderThumb.Position = UDim2.new(ratio, -9, 0, -6)
	updateFOVOverlay()
end)

-- Main render loop (aimbot + ESP update)
local renderConnection: RBXScriptConnection = runService.RenderStepped:Connect(function()
	-- Aimbot: just rotates camera, no CameraType change
	if aimbotEnabled then
		local _, targetPos: Vector3? = getClosestTarget()
		if targetPos then
			local cameraPos: Vector3 = camera.CFrame.Position
			camera.CFrame = CFrame.lookAt(cameraPos, targetPos)
		end
	end

	-- ESP update
	updateESP()
end)

-- Player join: add ESP
playersService.PlayerAdded:Connect(function(newPlayer: Player)
	refreshPlayerList()
	newPlayer.CharacterAdded:Connect(function()
		setupESPForCharacter(newPlayer)
	end)
	if newPlayer.Character then
		setupESPForCharacter(newPlayer)
	end
end)

-- Player leave: clean up ESP
playersService.PlayerRemoving:Connect(function(leavingPlayer: Player)
	refreshPlayerList()
	if espElements[leavingPlayer] then
		removeESP(leavingPlayer)
	end
end)

-- ESP setup for existing players
for _, p: Player in ipairs(playersService:GetPlayers()) do
	if p ~= player then
		p.CharacterAdded:Connect(function()
			setupESPForCharacter(p)
		end)
		if p.Character then
			task.spawn(function()
				task.wait(0.3)
				createESP(p)
			end)
		end
	end
end

-- Initial setup
refreshPlayerList()
updateFOVOverlay()
