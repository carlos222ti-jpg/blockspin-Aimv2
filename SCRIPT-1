local function getClosestTarget(): (Player?, Vector3?)
	local closestPlayer: Player? = nil
	local closestDistance: number = math.huge
	local targetPosition: Vector3? = nil

	local cameraPos: Vector3 = camera.CFrame.Position
	local screenCenter: Vector2 = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)

	local players: { Player } = playersService:GetPlayers()

	for _, otherPlayer: Player in ipairs(players) do
		if otherPlayer == player then
			continue
		end
		if excludedPlayers[otherPlayer] then
			continue
		end

		local character: Model? = otherPlayer.Character
		if not character then
			continue
		end

		local head: BasePart? = character:FindFirstChild("Head")
		if not head then
			continue
		end

		local headPos: Vector3 = head.Position
		local screenPos: Vector3, onScreen: boolean = camera:WorldToScreenPoint(headPos)
		if not onScreen then
			continue
		end

		local distanceFromCenter: number = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
		if distanceFromCenter <= fovSize then
			local distance: number = (headPos - cameraPos).Magnitude
			if distance < closestDistance then
				closestDistance = distance
				closestPlayer = otherPlayer
				targetPosition = headPos
			end
		end
	end

	return closestPlayer, targetPosition
end

-- === ESP ===

local function looksLikeActionState(name: string): boolean
	local lower: string = name:lower()
	local keywords: { string } = {
		"anim", "animation", "sound", "sfx", "hit", "reload", "shoot", "fire",
		"equip", "unequip", "idle", "charge", "aim", "aiming", "kick", "recoil",
		"pump", "cock", "draw", "holster", "muzzle", "barrel", "casing", "shell",
		"particle", "effect", "vfx", "trail", "smoke", "flash", "spark", "explosion",
		"swing", "strike", "slash", "attack", "damage", "impact", "block", "parry",
		"dash", "walk", "run", "jump", "fall", "land", "death", "spawn", "stun",
		"critical", "combo", "special", "ultimate", "remote", "gui", "weld",
		"attachment", "config", "value", "motor", "constraint", "force",
	}
	for _, keyword: string in ipairs(keywords) do
		if lower:find(keyword) then
			return true
		end
	end
	if tonumber(name) then
		return true
	end
	return false
end

local function cleanToolName(name: string): string
	local cleaned: string = name
	local prefixes: { string } = { "tools_cinder_", "tool_", "cinder_", "weapon_", "item_", "tools_", "gear_", "weapons_" }
	for _, prefix: string in ipairs(prefixes) do
		if cleaned:lower():sub(1, #prefix) == prefix then
			cleaned = cleaned:sub(#prefix + 1)
			break
		end
	end
	cleaned = cleaned:gsub("[_-]", " ")
	cleaned = cleaned:gsub("%s+", " ")
	cleaned = cleaned:sub(1, 1):upper() .. cleaned:sub(2)
	return cleaned
end

local function getWeaponName(tool: Tool): string
	-- 1. Server-tagged attribute (set by WeaponTagger script)
	local attrName: string? = tool:GetAttribute("ESP_WeaponName")
	if attrName and attrName ~= "" and attrName ~= "None" then
		return attrName
	end

	-- 2. ToolTip
	if tool.ToolTip ~= "" and not looksLikeActionState(tool.ToolTip) then
		return cleanToolName(tool.ToolTip)
	end

	-- 3. Tool name (if it doesn't look like an animation/sound)
	if not looksLikeActionState(tool.Name) then
		return cleanToolName(tool.Name)
	end

	return "None"
end

local function getToolList(targetPlayer: Player): { string }
	local weapons: { string } = {}

	local character: Model? = targetPlayer.Character
	if character then
		for _, child: Instance in ipairs(character:GetChildren()) do
			if child:IsA("Tool") then
				local name: string = getWeaponName(child :: Tool)
				if name ~= "None" then
					table.insert(weapons, name)
				end
			end
		end
	end

	local backpack: Backpack? = targetPlayer:FindFirstChildOfClass("Backpack")
	if backpack then
		for _, child: Instance in ipairs(backpack:GetChildren()) do
			if child:IsA("Tool") then
				local name: string = getWeaponName(child :: Tool)
				if name ~= "None" then
					table.insert(weapons, name)
				end
			end
		end
	end

	return weapons
end

local function createESP(targetPlayer: Player): ()
	if targetPlayer == player then
		return
	end
	if espElements[targetPlayer] then
		return
	end

	local character: Model? = targetPlayer.Character
	if not character then
		return
	end

	-- Highlight
	local highlight = Instance.new("Highlight")
	highlight.Name = "ESP_Highlight"
	highlight.Adornee = character
	highlight.FillColor = Color3.fromRGB(255, 100, 100)
	highlight.OutlineColor = Color3.fromRGB(255, 200, 200)
	highlight.FillTransparency = 0.55
	highlight.OutlineTransparency = 0.2
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Parent = character

	-- BillboardGui
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "ESP_Billboard"
	billboard.Size = UDim2.new(0, 150, 0, 50)
	billboard.StudsOffsetWorldSpace = Vector3.new(0, 3, 0)
	billboard.AlwaysOnTop = true
	billboard.ClipsDescendants = false

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "Name"
	nameLabel.Size = UDim2.new(1, 0, 0, 18)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text = targetPlayer.Name
	nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	nameLabel.TextScaled = true
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextStrokeTransparency = 0.4
	nameLabel.Parent = billboard

	local statsLabel = Instance.new("TextLabel")
	statsLabel.Name = "Stats"
	statsLabel.Size = UDim2.new(1, 0, 0, 16)
	statsLabel.Position = UDim2.new(0, 0, 0, 18)
	statsLabel.BackgroundTransparency = 1
	statsLabel.Text = "HP: 100 | 0m"
	statsLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
	statsLabel.TextScaled = true
	statsLabel.Font = Enum.Font.GothamMedium
	statsLabel.TextStrokeTransparency = 0.5
	statsLabel.Parent = billboard

	local itemLabel = Instance.new("TextLabel")
	itemLabel.Name = "Item"
	itemLabel.Size = UDim2.new(1, 0, 0, 16)
	itemLabel.Position = UDim2.new(0, 0, 0, 34)
	itemLabel.BackgroundTransparency = 1
	itemLabel.Text = "None"
	itemLabel.TextColor3 = Color3.fromRGB(255, 200, 80)
	itemLabel.TextScaled = true
	itemLabel.Font = Enum.Font.GothamMedium
	itemLabel.TextStrokeTransparency = 0.5
	itemLabel.Parent = billboard

	local head: BasePart? = character:FindFirstChild("Head")
	if head then
		billboard.Parent = head
	else
		local root: BasePart? = character:FindFirstChild("HumanoidRootPart")
		if root then
			billboard.StudsOffsetWorldSpace = Vector3.new(0, 0, 0)
			billboard.Parent = root
		end
	end

	espElements[targetPlayer] = {
		highlight = highlight,
		billboard = billboard,
		nameLabel = nameLabel,
		statsLabel = statsLabel,
		itemLabel = itemLabel,
	}

	-- If ESP is disabled, hide it immediately
	if not espEnabled then
		highlight.Enabled = false
		billboard.Enabled = false
	end
end

local function removeESP(targetPlayer: Player): ()
	local esp = espElements[targetPlayer]
	if not esp then
		return
	end

	esp.highlight:Destroy()
	esp.billboard:Destroy()
	espElements[targetPlayer] = nil
end

local function updateESP(): ()
	if not espEnabled then
		return
	end

	local cameraPos: Vector3 = camera.CFrame.Position

	for targetPlayer, esp in espElements do
		local character: Model? = targetPlayer.Character
		if not character then
			removeESP(targetPlayer)
			continue
		end

		local humanoid: Humanoid? = character:FindFirstChildOfClass("Humanoid")
		local head: BasePart? = character:FindFirstChild("Head")

		if not humanoid or not head then
			esp.statsLabel.Text = "HP: ? | Dist: ?"
			continue
		end

		-- Health + distance combined
		local health: number = math.floor(humanoid.Health + 0.5)
		local maxHealth: number = math.floor(humanoid.MaxHealth + 0.5)
		local dist: number = math.floor((head.Position - cameraPos).Magnitude + 0.5)
		esp.statsLabel.Text = "HP: " .. tostring(health) .. "/" .. tostring(maxHealth) .. " | " .. tostring(dist) .. "m"

		if health > 60 then
			esp.statsLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
		elseif health > 30 then
			esp.statsLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
		else
			esp.statsLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
		end

		-- Items (up to 3 weapons from equipped + backpack)
		local weapons: { string } = getToolList(targetPlayer)
		if #weapons == 0 then
			esp.itemLabel.Text = "None"
		else
			local display: string = ""
			for i = 1, math.min(#weapons, 3) do
				if i > 1 then
					display ..= ", "
				end
				display ..= weapons[i]
			end
			if #weapons > 3 then
				display ..= " +" .. tostring(#weapons - 3)
			end
			esp.itemLabel.Text = display
		end

		-- Re-parent billboard if character respawned
		if esp.billboard.Parent ~= head then
			esp.billboard.Parent = head
			esp.billboard.StudsOffsetWorldSpace = Vector3.new(0, 3.5, 0)
		end

		-- Update highlight Adornee if character changed
		if esp.highlight.Adornee ~= character then
			esp.highlight.Adornee = character
		end
	end
end

local function toggleESP(): ()
	espEnabled = not espEnabled
	if espEnabled then
		espBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
		espBtn.Text = "ESP: ON"
	else
		espBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
		espBtn.Text = "ESP: OFF"
	end

	for _, esp in espElements do
		esp.highlight.Enabled = espEnabled
		esp.billboard.Enabled = espEnabled
	end
end

-- === Minimize / Restore ===

local function minimizeGUI(): ()
	guiMinimized = true
	mainFrame.Visible = false
	minBar.Visible = true
end

local function restoreGUI(): ()
	guiMinimized = false
	mainFrame.Visible = true
	minBar.Visible = false
end

local function setupESPForCharacter(targetPlayer: Player): ()
	-- Clean up old ESP if it exists
	if espElements[targetPlayer] then
		removeESP(targetPlayer)
	end

	-- Create new ESP (creates for the latest character)
	task.wait(0.3)
	createESP(targetPlayer)
end

